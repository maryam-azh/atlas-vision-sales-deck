# Git LFS configuration for large media files
# Video files
*.mp4 filter=lfs diff=lfs merge=lfs -text
*.mov filter=lfs diff=lfs merge=lfs -text
*.avi filter=lfs diff=lfs merge=lfs -text
*.webm filter=lfs diff=lfs merge=lfs -text
# Large image files in assets
src/assets/*.png filter=lfs diff=lfs merge=lfs -text
src/assets/*.jpg filter=lfs diff=lfs merge=lfs -text
src/assets/*.jpeg filter=lfs diff=lfs merge=lfs -text
src/assets/*.gif filter=lfs diff=lfs merge=lfs -text
# Large video files in assets
src/assets/*.mp4 filter=lfs diff=lfs merge=lfs -text
# Other large archives
*.zip filter=lfs diff=lfs merge=lfs -text
*.tar.gz filter=lfs diff=lfs merge=lfs -text
src/assets/intro-movie.mp4 filter=lfs diff=lfs merge=lfs -text
